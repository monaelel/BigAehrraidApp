<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_ag_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="80dp"
            android:paddingBottom="32dp"
            android:gravity="center_horizontal">

            <!-- ── Logo Section with floating glow ────────────── -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal">

                <View
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_ag_logo_glow"
                    android:alpha="0.5" />

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:translationZ="6dp"
                    android:contentDescription="Big Aehrraid Logo" />
            </FrameLayout>

            <!-- ── App Title ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Big Aehrraid"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/ag_text_primary"
                android:letterSpacing="0.04"
                android:layout_marginTop="6dp" />

            <!-- ── Glass Card for form ────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardRegisterForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/shape_ag_glass_card"
                android:elevation="6dp"
                android:translationZ="4dp"
                android:padding="24dp"
                android:layout_marginTop="24dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE YOUR ACCOUNT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ag_primary"
                    android:letterSpacing="0.12" />

                <!-- Email field -->
                <EditText
                    android:id="@+id/etRegisterEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:layout_marginTop="18dp"
                    android:importantForAutofill="yes"
                    android:autofillHints="emailAddress" />

                <!-- Password field -->
                <EditText
                    android:id="@+id/etRegisterPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:layout_marginTop="14dp"
                    android:importantForAutofill="yes"
                    android:autofillHints="password" />

                <!-- Confirm Password field -->
                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Confirm Password"
                    android:inputType="textPassword"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:layout_marginTop="14dp" />

                <!-- Description (Restaurants Only) -->
                <EditText
                    android:id="@+id/et_register_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:hint="Description (Restaurants Only)"
                    android:inputType="textMultiLine"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:visibility="gone"
                    android:layout_marginTop="14dp" />

                <!-- Opening Hours (Restaurants Only) -->
                <EditText
                    android:id="@+id/et_register_opening_hours"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Opening Hours (e.g. 9 AM - 10 PM)"
                    android:inputType="text"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:visibility="gone"
                    android:layout_marginTop="14dp" />

                <!-- Hidden role selection (only customers self-register) -->
                <RadioGroup
                    android:id="@+id/rgUserRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">
                    <RadioButton android:id="@+id/rbCustomer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                    <RadioButton android:id="@+id/rbRestaurant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </RadioGroup>

                <!-- Sign Up Button -->
                <Button
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Sign Up"
                    android:background="@drawable/shape_ag_btn_primary"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:letterSpacing="0.02"
                    android:elevation="8dp"
                    android:translationZ="4dp"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="20dp" />

            </LinearLayout>

            <!-- ── Go to Login link ───────────────────────────── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textSize="14sp"
                    android:textColor="@color/ag_text_secondary" />

                <TextView
                    android:id="@+id/tvGoToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIGN IN"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/ag_primary"
                    android:letterSpacing="0.05"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/shape_ag_link_bg"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Floating back button ───────────────────────────── -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp"
        android:padding="10dp"
        android:background="@drawable/shape_ag_back_btn"
        android:elevation="4dp"
        android:translationZ="2dp"
        android:src="@drawable/ic_back_arrow"
        android:contentDescription="Back"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
