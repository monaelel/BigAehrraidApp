<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/shape_ag_bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="80dp"
            android:paddingBottom="32dp"
            android:gravity="center_horizontal">

            <!-- ── Logo Section with floating glow ────────────── -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal">

                <!-- Radial glow behind logo -->
                <View
                    android:id="@+id/viewLogoGlow"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_ag_logo_glow"
                    android:alpha="0.6" />

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:translationZ="6dp"
                    android:contentDescription="Big Aehrraid Logo" />
            </FrameLayout>

            <!-- ── App Title ──────────────────────────────────── -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Big Aehrraid"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/ag_text_primary"
                android:letterSpacing="0.04"
                android:layout_marginTop="8dp" />

            <!-- ── Subtitle ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textSize="14sp"
                android:textColor="@color/ag_text_secondary"
                android:layout_marginTop="4dp" />

            <!-- ── Glass Card for form ────────────────────────── -->
            <LinearLayout
                android:id="@+id/cardLoginForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/shape_ag_glass_card"
                android:elevation="6dp"
                android:translationZ="4dp"
                android:padding="24dp"
                android:layout_marginTop="28dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIGN IN"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ag_primary"
                    android:letterSpacing="0.12" />

                <!-- Email field -->
                <EditText
                    android:id="@+id/et_login_email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:layout_marginTop="18dp"
                    android:importantForAutofill="yes"
                    android:autofillHints="emailAddress" />

                <!-- Password field -->
                <EditText
                    android:id="@+id/etLoginPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:background="@drawable/shape_ag_input"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="15sp"
                    android:textColor="@color/ag_text_primary"
                    android:textColorHint="@color/ag_text_hint"
                    android:layout_marginTop="14dp"
                    android:importantForAutofill="yes"
                    android:autofillHints="password" />

                <!-- Remember me / Forgot password row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <CheckBox
                        android:id="@+id/cbRememberMe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remember me"
                        android:textSize="13sp"
                        android:textColor="@color/ag_text_secondary"
                        android:buttonTint="@color/ag_primary"
                        android:minHeight="36dp" />

                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot Password?"
                        android:textSize="13sp"
                        android:textColor="@color/ag_primary"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <!-- Sign In Button -->
                <Button
                    android:id="@+id/btnSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Sign In"
                    android:background="@drawable/shape_ag_btn_primary"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:letterSpacing="0.02"
                    android:elevation="8dp"
                    android:translationZ="4dp"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="20dp" />

            </LinearLayout>

            <!-- ── Customer: Create Account link ─────────────── -->
            <LinearLayout
                android:id="@+id/layoutCreateAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?"
                    android:textSize="14sp"
                    android:textColor="@color/ag_text_secondary" />

                <TextView
                    android:id="@+id/tvGoToRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE ACCOUNT"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/ag_primary"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/shape_ag_link_bg"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- ── Restaurant: contact admin message ─────────── -->
            <TextView
                android:id="@+id/tvContactAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please contact admin to create account as a business"
                android:textColor="@color/ag_text_hint"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Floating back button ───────────────────────────── -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp"
        android:padding="10dp"
        android:background="@drawable/shape_ag_back_btn"
        android:elevation="4dp"
        android:translationZ="2dp"
        android:src="@drawable/ic_back_arrow"
        android:contentDescription="Back"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
