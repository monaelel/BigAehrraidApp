<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_ag_card_elevated"
    android:orientation="vertical"
    android:elevation="2dp"
    android:layout_marginBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@drawable/shape_ag_image_frame"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textColor="@color/ag_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProductStocks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stocks: —"
                android:textColor="@color/ag_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price: $0.00 / unit"
                android:textColor="@color/ag_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Thin divider above actions -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ag_divider"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnDeleteProduct"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Delete"
            android:textSize="13sp"
            android:textColor="@color/ag_error"
            android:background="@drawable/shape_ag_btn_danger_outline"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnEditProduct"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Edit"
            android:textSize="13sp"
            android:textColor="@color/ag_primary"
            android:background="@drawable/shape_ag_btn_outlined"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnToggleAvailable"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Available"
            android:textSize="13sp"
            android:textColor="@color/ag_success"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            android:background="@drawable/shape_ag_btn_outlined"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
