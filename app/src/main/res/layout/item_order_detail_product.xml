<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_ag_card_elevated"
    android:orientation="horizontal"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:elevation="1dp"
    android:layout_marginBottom="10dp">

    <!-- Item photo placeholder -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/shape_ag_image_frame"
        android:layout_marginEnd="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Item\nphoto"
            android:textSize="9sp"
            android:textColor="@color/ag_text_hint"
            android:gravity="center" />

    </FrameLayout>

    <!-- Product name + qty x price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ Product Name ]"
            android:textColor="@color/ag_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvQtyPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ qty ] x $ [price]"
            android:textColor="@color/ag_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Total price for this line -->
    <TextView
        android:id="@+id/tvItemTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ [price]"
        android:textColor="@color/ag_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
