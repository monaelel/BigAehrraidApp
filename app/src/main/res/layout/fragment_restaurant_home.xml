<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <!-- SALES title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SALES"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="8dp" />

    <!-- Total sales amount -->
    <TextView
        android:id="@+id/tvTotalSales"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$ [Total sales amount]"
        android:textSize="15sp"
        android:textColor="#444444"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Bar chart -->
    <com.example.bigaehrraidapp.SalesBarChartView
        android:id="@+id/salesBarChart"
        android:layout_width="match_parent"
        android:layout_height="180dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Order Volume row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order Volume"
            android:textColor="#444444"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvOrderVolume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="193"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Ticket Size row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ticket Size"
            android:textColor="#444444"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvTicketSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$23.35"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Spacer pushes button to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Manage Order button -->
    <Button
        android:id="@+id/btnManageOrder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#000000"
        android:text="Manage Order"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

</LinearLayout>
