                        android:layout_height="wrap_content"
                        android:text="10:00 PM"
                        android:textColor="@color/ag_text_primary"
                        android:textSize="14sp"
                        android:padding="4dp"
                        android:background="@drawable/shape_ag_card_elevated" />

                </LinearLayout>
            </LinearLayout>

            <!-- Wednesday -->
