                        android:padding="4dp"
                        android:background="@drawable/shape_ag_card_elevated" />

                </LinearLayout>
            </LinearLayout>

            <!-- Friday -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_ag_card_elevated"
                android:orientation="vertical"
                android:padding="14dp"
