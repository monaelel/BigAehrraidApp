                        android:textColor="@color/ag_text_hint" />

                    <TextView
                        android:id="@+id/tvCloseWednesday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10:00 PM"
                        android:textColor="@color/ag_text_primary"
                        android:textSize="14sp"
                        android:padding="4dp"
                        android:background="@drawable/shape_ag_card_elevated" />

                </LinearLayout>
            </LinearLayout>

            <!-- Thursday -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_ag_card_elevated"
                android:orientation="vertical"
