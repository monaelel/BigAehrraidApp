                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvOpenFriday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:00 AM"
                        android:textColor="@color/ag_text_primary"
                        android:textSize="14sp"
                        android:padding="4dp"
                        android:background="@drawable/shape_ag_card_elevated" />

                    <TextView
                        android:layout_width="wrap_content"
