<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ag_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:paddingTop="80dp"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Big Aehrraid"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/ag_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SET UP YOUR RESTAURANT"
                android:layout_marginTop="24dp"
                android:textStyle="bold"
                android:textColor="@color/ag_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All fields are required."
                android:textSize="12sp"
                android:textColor="@color/ag_text_hint"
                android:layout_marginTop="4dp" />

            <EditText
                android:id="@+id/etSetupName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Restaurant Name"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/etSetupPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number (e.g. 416-555-1234)"
                android:inputType="phone"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/etSetupContactEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact Email"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/etSetupStreet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Street Address"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/etSetupCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="City"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Province / Territory"
                android:textSize="12sp"
                android:textColor="@color/ag_text_hint"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="2dp" />

            <Spinner
                android:id="@+id/spinnerProvince"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_ag_card_elevated"
                android:padding="12dp" />

            <EditText
                android:id="@+id/etSetupPostalCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Postal Code (e.g. A1A 1A1)"
                android:inputType="textCapCharacters"
                android:maxLength="7"
                android:padding="12dp"
                android:textColor="@color/ag_text_primary"
                android:textColorHint="@color/ag_text_hint"
                android:background="@drawable/shape_ag_card_elevated"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnSetupSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save &amp; Continue"
                android:background="@drawable/shape_ag_btn_primary"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="56dp"
        android:layout_marginStart="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_back_arrow"
        android:contentDescription="Back" />

</FrameLayout>
