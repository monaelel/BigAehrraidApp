<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/ag_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Account"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/ag_text_primary"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnAccountInformation"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Account Information"
        android:textSize="16sp"
        android:background="@drawable/shape_ag_btn_primary"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnManageStoreHours"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Manage Store Hours"
        android:textSize="16sp"
        android:background="@drawable/shape_ag_btn_outlined"
        android:textColor="@color/ag_primary"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Logout"
        android:textSize="16sp"
        android:textColor="@color/ag_error"
        android:background="@drawable/shape_ag_btn_danger_outline"
        android:textAllCaps="false"
        android:stateListAnimator="@null" />

</LinearLayout>
