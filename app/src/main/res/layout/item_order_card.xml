<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_ag_card_elevated"
    android:orientation="vertical"
    android:padding="16dp"
    android:elevation="2dp"
    android:layout_marginBottom="14dp">

    <!-- Row 1: Order ID + Status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvOrderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order #372873"
            android:textColor="@color/ag_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_ag_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Incoming"
            android:textColor="@color/ag_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

    </LinearLayout>

    <!-- Row 2: Customer name -->
    <TextView
        android:id="@+id/tvCustomerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="[ Customer Name ]"
        android:textColor="@color/ag_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ag_divider"
        android:layout_marginBottom="12dp" />

    <!-- Row 3: Item count + Total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/tvItemCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="[ Count ] items"
            android:textColor="@color/ag_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ [amount]"
            android:textColor="@color/ag_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Action buttons — shown/hidden based on status -->

    <!-- Incoming: Accept + Decline -->
    <LinearLayout
        android:id="@+id/layoutIncomingButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/shape_ag_btn_accent"
            android:text="Accept"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnDecline"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/shape_ag_btn_danger_outline"
            android:text="Decline"
            android:textColor="@color/ag_error"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- Preparing: Ready -->
    <Button
        android:id="@+id/btnReady"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/shape_ag_btn_outlined"
        android:text="Ready"
        android:textColor="@color/ag_primary"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        android:visibility="gone" />

</LinearLayout>
