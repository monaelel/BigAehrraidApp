<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ag_bg">

    <FrameLayout
        android:id="@+id/restaurantFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/restaurantBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ag_surface"
        android:elevation="8dp"
        app:menu="@menu/restaurant_bottom_nav_menu"
        app:itemIconTint="@color/ag_primary"
        app:itemTextColor="@color/ag_primary"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
