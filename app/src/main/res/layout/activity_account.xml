<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layout_menu_inferior"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/pastelgreen" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Account"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/darkergreen" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="30dp">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@color/lightgreen"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/sillyCat"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Silly Mc.Cat"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkergreen"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="silly@cat.meow"
                    android:textColor="#757575"/>
            </LinearLayout>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Personal Data Settings"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:backgroundTint="@color/whitegreen"
                android:textColor="@color/darkergreen"
                android:layout_marginBottom="8dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Leave a Review"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:backgroundTint="@color/whitegreen"
                android:textColor="@color/darkergreen"
                android:layout_marginBottom="8dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="About Us"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:backgroundTint="@color/whitegreen"
                android:textColor="@color/darkergreen"
                android:layout_marginBottom="8dp"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="More Help"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:backgroundTint="@color/whitegreen"
                android:textColor="@color/darkergreen"
                android:layout_marginBottom="20dp"/>

            <Button
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="logout"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp"
                android:backgroundTint="@color/whitegreen"
                android:textColor="@color/darkergreen"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_menu_inferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:orientation="horizontal"
        android:elevation="10dp">

        <Button
            android:id="@+id/btnHomeDeals"
            android:text="Deals"
            android:backgroundTint="@color/green"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/BtnHomeAccount"
            android:text="Account"
            android:backgroundTint="@color/green"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/BtnHomeMap"
            android:text="Map"
            android:backgroundTint="@color/green"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"/>
    </LinearLayout>

</RelativeLayout>