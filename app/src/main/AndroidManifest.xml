<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BigAehrraidApp">
        <activity
            android:name=".SplashScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".CheckoutActivity" android:exported="false" />
        <activity android:name=".CartActivity" android:exported="false" />
        <activity android:name=".ActivityAuthLogin" android:exported="false" />
        <activity android:name=".ActivityAuthRegister" android:exported="false" />
        <activity android:name=".AddEditCategoryActivity" android:exported="false" />
        <activity android:name=".AddProductActivity" android:exported="false" />
        <activity android:name=".CustomerMainActivity" android:exported="false" />
        <activity android:name=".CustomerRestaurantMenuActivity" android:exported="false" />
        <activity android:name=".EditProductActivity" android:exported="false" />
        <activity android:name=".ManageCategoriesActivity" android:exported="false" />
        <activity android:name=".ManageOrderActivity" android:exported="false" />
        <activity android:name=".OrderDetailActivity" android:exported="false" />
        <activity android:name=".RestaurantListActivity" android:exported="false" />
        <activity android:name=".RestaurantMainActivity" android:exported="false" />
        <activity android:name=".RestaurantSetupActivity" android:exported="false" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />
    </application>

</manifest>